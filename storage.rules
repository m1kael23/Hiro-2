rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Company assets (logos + culture photos) ──────────────────
    // Employers may read/write only under their own UID prefix.
    // Anyone authenticated may read (needed for candidate-facing previews).
    match /company/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size  < 2 * 1024 * 1024          // 2 MB cap
                   && request.resource.contentType.matches('image/.*');  // images only
    }

    // ── Candidate uploads (CV PDFs, profile photos) ───────────────
    match /candidates/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024;           // 5 MB cap
    }

    // ── Default deny ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
